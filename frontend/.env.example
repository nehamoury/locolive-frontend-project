# LocoLive Frontend — Development Environment
# ⚠️ For production, copy to .env.production and update values
VITE_API_URL=http://localhost:8080/api
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=locolive-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=locolive-project
VITE_FIREBASE_STORAGE_BUCKET=locolive-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID
VITE_FIREBASE_MEASUREMENT_ID=YOUR_MEASUREMENT_ID
